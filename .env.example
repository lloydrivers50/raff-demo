# Copy this file to .env and fill in your Azure App Registration values
# Get these from: portal.azure.com → Azure Active Directory → App registrations

VITE_AZURE_CLIENT_ID=your-application-client-id-here
VITE_AZURE_TENANT_ID=your-directory-tenant-id-here

# For local dev this defaults to window.location.origin automatically
# VITE_REDIRECT_URI=http://localhost:3000
